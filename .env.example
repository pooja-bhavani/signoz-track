# SigNoz OTLP endpoint (required)
SIGNOZ_ENDPOINT=http://<your-signoz-ip>:4318

# Load generator settings
RPS=5

# LLM settings (optional — fraud detection works with simulated responses by default)
USE_REAL_LLM=false
ANTHROPIC_API_KEY=

# SigNoz API (for RCA agent)
SIGNOZ_API_URL=http://<your-signoz-ip>:8080/api/v1
SIGNOZ_ACCESS_TOKEN=
